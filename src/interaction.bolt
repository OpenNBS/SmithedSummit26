    playsound minecraft:block.note_block.guitar block @a[distance=..8] ~ ~ ~ 1 0.891
    playsound minecraft:block.note_block.guitar block @a[distance=..8] ~ ~ ~ 1 0.794
    playsound minecraft:block.note_block.guitar block @a[distance=..8] ~ ~ ~ 1 1.059
